# Spotify OAuth (Authorization Code + PKCE). Register the redirect URI exactly in the
# Spotify Developer Dashboard (scheme, host, port, path, trailing slash).

SPOTIFY_CLIENT_ID=

# HTTPS dev server (bun run dev uses --experimental-https), e.g.:
SPOTIFY_REDIRECT_URI=https://localhost:3000/api/auth/spotify/callback

# Long random string used to encrypt httpOnly Spotify session cookies.
# Preferred name below; SESSION_SECRET is also accepted as an alias in code.
SPOTIFY_SESSION_SECRET=

# Alternate name for SPOTIFY_SESSION_SECRET (either one may be set):
# SESSION_SECRET=
